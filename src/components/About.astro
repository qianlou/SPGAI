              <path d="M12 8v4l3 3"/>
              <path d="M9 12h.01M15 12h.01"/>
            </svg>
          </div>
          <h3 class="text-lg font-semibold mb-2 text-primary-900">Security & Privacy by Design</h3>
          <p class="text-gray-600">Explore cutting-edge research in watermarking, verifiable computing, homomorphic encryption, and confidential AI accelerators tailored for generative and agentic systems.</p>
        </div>
        
        <div class="bg-primary-50 p-6 rounded-lg border border-primary-100 hover:shadow-md transition-shadow duration-300">
          <div class="text-primary-600 mb-3">
            <svg xmlns="http://www.w3.org/2000/svg" width="34" height="34" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
