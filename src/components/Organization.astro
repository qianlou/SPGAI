---
import mxImage from "../assets/team/mx.jpeg";
import QLImage from "../assets/team/lq.jpg";
import WuImage from "../assets/team/wu.jpg";

type Person = {
  name: string;
  title?: string;
  affiliation: string;
  link?: string;
  img?: string;
};

type OrganizerCategory = {
  category: string;
  people: Person[];
};

const organizers: OrganizerCategory[] = [
  {
    category: "Organization Team",
    people: [
      { name: "Qian Lou", title: "Assistant Professor", affiliation: "University of Central Florida, USA", link: "https://www.qlou.org/", img: QLImage.src },
      { name: "Hongyi Michael Wu", title: "Professor", affiliation: "University of Arizona, USA", link: "https://wu.static.arizona.edu/", img: WuImage.src },
      { name: "Mengxin Zheng", title: "Assistant Professor", affiliation: "University of Central Florida, USA", link: "https://mxzheng.github.io/", img: mxImage.src },
     ]
  },
];
---

<section id="organization" class="py-16 md:py-24 bg-white">
  {console.log(dkImage.src)}
  <div class="container mx-auto px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl md:text-3xl font-bold text-center mb-8 text-primary-800 animate-on-scroll">
        Workshop Organization
      </h2>
      
      <div class="space-y-10 animate-on-scroll">
        {organizers.map((category) => (
            <div>
            <h3 class="text-xl font-semibold mb-4 text-primary-700 border-b border-primary-200 pb-2">
              {category.category}
            </h3>
            
            <div class="grid md:grid-cols-2 gap-4">
              {category.people.map((person) => (
              <div class="flex items-center bg-gray-50 p-4 rounded-lg hover:shadow-sm transition-shadow duration-300">
                {person.img && (
                <img
                  src={person.img}
                  alt={person.name}
                  class="w-20 h-20 rounded-full mr-4"
                />
                )}
                <div>
                <h4 class="font-medium text-secondary-800">
                  {person.link ? (
                  <a
                    href={person.link}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-primary-600 hover:underline"
                  >
                    {person.name}
                  </a>
                  ) : (
                  person.name
                  )}
                </h4>
                {person.title && (
                  <p class="text-sm text-gray-500">{person.title}</p>
                )}
                <p class="text-sm text-gray-600">{person.affiliation}</p>
                </div>
              </div>
              ))}
            </div>
            </div>
        ))}
      </div>
      
